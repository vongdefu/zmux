{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zmux",
  "version": "1.0.0",
  "identifier": "vongdefu.github.io",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zmux",
        "width": 412,
        "height": 840,
        "minWidth": 360,
        "minHeight": 640,
        "maxWidth": 480,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "iOS": {
      "developmentTeam": "233QHB3XPJ"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}